# ─── Polymarket ───────────────────────────────────────────────────────────────
# Your Polygon/Ethereum private key (0x-prefixed)
# Must be funded with USDC on Polygon for live trading
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# ─── Binance ──────────────────────────────────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/stream

# ─── Symbols ──────────────────────────────────────────────────────────────────
# Comma-separated list — must match Polymarket active market symbols
SYMBOLS=BTC,ETH,SOL

# ─── Sniper Windows ───────────────────────────────────────────────────────────
# Seconds before 5-min candle end to START monitoring
SNIPE_WINDOW_START=45
# Seconds before 5-min candle end to STOP entering (avoid settlement lag)
SNIPE_WINDOW_END=5

# ─── Signal Thresholds ────────────────────────────────────────────────────────
# Minimum % price move from candle open to trigger signal
MIN_PRICE_CHANGE_PCT=0.3
# Minimum confidence score (0-100) before placing order
MIN_CONFIDENCE=65

# ─── Risk Management ─────────────────────────────────────────────────────────
# Maximum size of a single position in USD
MAX_POSITION_USD=10
# Maximum number of concurrent open positions
MAX_CONCURRENT_POSITIONS=3
# Hard stop for the day if losses exceed this amount
DAILY_LOSS_LIMIT_USD=25
# Slippage buffer added above best ask price
SLIPPAGE_BUFFER=0.02

# ─── Execution Mode ───────────────────────────────────────────────────────────
# Set to false only when you're ready to trade real money
DRY_RUN=true

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Your Telegram chat/user ID (get from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
