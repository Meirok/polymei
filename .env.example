# ─── Polymarket ───────────────────────────────────────────────────────────────
# Private key of the SIGNER/OPERATOR wallet (0x-prefixed).
# For signatureType=0: this wallet is also the funder (needs on-chain USDC).
# For signatureType=2: this is only the operator key; USDC lives in the Privy account.
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# Signature type for order signing:
#   0 = EOA (standard wallet — maker === signer === wallet.address, requires on-chain USDC)
#   1 = POLY_PROXY / Magic Link
#   2 = POLY_GNOSIS_SAFE / Privy-Gmail (uses internal Polymarket balance, no on-chain USDC needed)
POLYMARKET_SIGNATURE_TYPE=0

# Funder address (signatureType=2 only) — the Privy/Gmail account address that holds
# the internal USDC balance on Polymarket.
# Example for signatureType=2:
#   POLYMARKET_FUNDER=0x6DCA9CF56363D1168684139945E74010b6e361Ea
# Leave EMPTY for signatureType=0 (funder defaults to wallet.address).
POLYMARKET_FUNDER=

# ─── Polymarket API Credentials ───────────────────────────────────────────────
# Pre-derived L2 API credentials. Leave empty to auto-derive on startup.
# For signatureType=2 (Privy): run the bot once with empty credentials — it will
# register the signer as operator via POST /auth/api-key and print the keys to the
# log. Then set them here to avoid re-registration on every restart.
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_PASSPHRASE=

# ─── Binance ──────────────────────────────────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/stream

# ─── Symbols ──────────────────────────────────────────────────────────────────
# Comma-separated list — must match Polymarket active market symbols
SYMBOLS=BTC,ETH,SOL

# ─── Scalper ──────────────────────────────────────────────────────────────────
# Sell when price rises this much from entry (e.g. 0.05 = sell at entry + 0.05)
SCALPER_PROFIT_TARGET=0.05
# Only enter if odds are at or below this value (near 50/50)
SCALPER_MAX_ENTRY_PRICE=0.52
# Force sell when this many seconds remain in the market window
SCALPER_FORCE_SELL_SECONDS=30
# Fixed position size in USD per market entry
SCALPER_POSITION_SIZE_USD=5

# ─── Risk Management ─────────────────────────────────────────────────────────
# Maximum number of concurrent open positions
MAX_CONCURRENT_POSITIONS=3
# Hard stop for the day if losses exceed this amount
DAILY_LOSS_LIMIT_USD=25
# Slippage buffer added above best ask price
SLIPPAGE_BUFFER=0.02
# Maximum total USDC committed across all open positions at once.
# Defaults to MAX_CONCURRENT_POSITIONS * SCALPER_POSITION_SIZE_USD.
# Set this to your wallet USDC balance to prevent "not enough balance" errors.
WALLET_BUDGET_USD=15

# ─── Execution Mode ───────────────────────────────────────────────────────────
# Set to false only when you're ready to trade real money
DRY_RUN=true

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Your Telegram chat/user ID (get from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id

# ─── Debug ────────────────────────────────────────────────────────────────────
# When true, sends 30-second loop status messages to Telegram (noisy — for diagnostics only)
DEBUG_MODE=false

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
