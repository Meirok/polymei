# ─── Polymarket ───────────────────────────────────────────────────────────────
# Your Polygon/Ethereum private key (0x-prefixed)
# Must be funded with USDC on Polygon for live trading
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# ─── Binance ──────────────────────────────────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/stream

# ─── Symbols ──────────────────────────────────────────────────────────────────
# Comma-separated list — must match Polymarket active market symbols
SYMBOLS=BTC,ETH,SOL

# ─── Scalper ──────────────────────────────────────────────────────────────────
# Sell when price rises this much from entry (e.g. 0.05 = sell at entry + 0.05)
SCALPER_PROFIT_TARGET=0.05
# Only enter if odds are at or below this value (near 50/50)
SCALPER_MAX_ENTRY_PRICE=0.52
# Force sell when this many seconds remain in the market window
SCALPER_FORCE_SELL_SECONDS=30
# Fixed position size in USD per market entry
SCALPER_POSITION_SIZE_USD=5

# ─── Risk Management ─────────────────────────────────────────────────────────
# Maximum number of concurrent open positions
MAX_CONCURRENT_POSITIONS=3
# Hard stop for the day if losses exceed this amount
DAILY_LOSS_LIMIT_USD=25
# Slippage buffer added above best ask price
SLIPPAGE_BUFFER=0.02

# ─── Execution Mode ───────────────────────────────────────────────────────────
# Set to false only when you're ready to trade real money
DRY_RUN=true

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# Your Telegram chat/user ID (get from @userinfobot)
TELEGRAM_CHAT_ID=your_chat_id

# ─── Debug ────────────────────────────────────────────────────────────────────
# When true, sends 30-second loop status messages to Telegram (noisy — for diagnostics only)
DEBUG_MODE=false

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
